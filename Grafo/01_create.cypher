// ============================================================
//  DB A GRAFO (Neo4j) - Piattaforma di streaming musicale
//  Dataset ESTESO: catalogo reale, gusti a cluster, ponti tra generi
//  Nodi:  Artist, Album, Track, Genre, User, Playlist
//  Archi: PUBLISHED, CONTAINS, OF_GENRE, SIMILAR_TO, FOLLOWS,
//         LISTENED, CREATED, INCLUDES
//  Archi con proprieta':
//    LISTENED   {conteggio:int>=1, timestamp:datetime}  numero di
//               riproduzioni e data/ora dell'ultimo ascolto.
//    SIMILAR_TO {stile, atmosfera, strumenti : float [0,1]}  punteggi
//               di similarita' (identici nei due archi speculari A<->B).
// ============================================================

// --- Pulizia del database (eseguire per ripartire da zero) ---
MATCH (n) DETACH DELETE n;

